{
  "name": "gm-daily-planner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/build-worker.mjs",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:planner:coverage": "vitest run src/planner --coverage --coverage.include=src/planner/**/*.ts --coverage.exclude=src/planner/**/*.test.ts",
    "test:planner-v3:coverage": "vitest run src/domain/planner-engine --coverage --coverage.include=src/domain/planner-engine/**/*.ts --coverage.exclude=src/domain/planner-engine/**/*.test.ts --coverage.exclude=src/domain/planner-engine/index.ts --coverage.thresholds.lines=95 --coverage.thresholds.functions=95 --coverage.thresholds.statements=95 --coverage.thresholds.branches=95",
    "test:ai:coverage": "vitest run src/core/ai --coverage --coverage.include=src/core/ai/**/*.ts --coverage.exclude=src/core/ai/**/*.test.ts --coverage.exclude=src/core/ai/features/**",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "test:e2e:remote": "node scripts/e2e-ai-remote.mjs",
    "audit:security": "node scripts/security-audit.mjs",
    "audit:calendar": "node scripts/audit-calendar-secrets.mjs",
    "backup": "node scripts/backup-supabase.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@sentry/react": "^10.67.0",
    "@supabase/supabase-js": "^2.110.7",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
